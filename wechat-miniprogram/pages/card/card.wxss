.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 56rpx;
  background:
    radial-gradient(circle at 76% 8%, rgba(42, 137, 255, 0.28), transparent 34%),
    linear-gradient(160deg, #071226 0%, #06122a 52%, #0c2857 100%);
}

.brand {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 34rpx;
}

.brand-mark {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 800;
  background: #2b6dea;
}

.brand-name {
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
}

.brand-en {
  margin-top: 4rpx;
  color: rgba(230, 241, 255, 0.72);
  font-size: 15rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.card {
  padding: 48rpx 36rpx 38rpx;
  border: 1rpx solid rgba(118, 166, 238, 0.35);
  border-radius: 28rpx;
  background: rgba(5, 15, 36, 0.76);
  box-shadow: 0 28rpx 80rpx rgba(0, 0, 0, 0.22);
}

.eyebrow {
  color: #57a5ff;
  font-size: 19rpx;
  font-weight: 800;
  letter-spacing: 6rpx;
}

.name {
  margin-top: 26rpx;
  color: #fff;
  font-size: 58rpx;
  font-weight: 800;
}

.role {
  margin-top: 16rpx;
  color: rgba(229, 239, 255, 0.78);
  font-size: 27rpx;
  font-weight: 600;
}

.role text {
  margin: 0 16rpx;
  color: rgba(150, 185, 238, 0.72);
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx 20rpx;
  margin-top: 38rpx;
  color: rgba(230, 241, 255, 0.82);
  font-size: 24rpx;
  font-weight: 700;
}

.contact {
  display: grid;
  gap: 24rpx;
  margin-top: 42rpx;
}

.contact-row {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  color: #eef6ff;
  font-size: 25rpx;
  line-height: 1.5;
}

.dot {
  width: 42rpx;
  height: 42rpx;
  flex: 0 0 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: #78b6ff;
  font-size: 22rpx;
  background: rgba(47, 105, 208, 0.22);
}

.portrait-wrap {
  margin: 48rpx auto 0;
  text-align: center;
}

.portrait {
  width: 220rpx;
  height: 260rpx;
  border-radius: 28rpx;
}

.portrait-name {
  margin-top: 18rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
}

.portrait-desc {
  margin-top: 8rpx;
  color: rgba(220, 235, 255, 0.68);
  font-size: 22rpx;
}

.actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 42rpx;
}

.action {
  min-height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
}

.primary {
  background: #2360df;
}

.secondary {
  border: 1rpx solid rgba(151, 192, 249, 0.5);
  background: rgba(255, 255, 255, 0.06);
}

.section {
  margin-top: 42rpx;
  padding: 34rpx 36rpx;
  border-radius: 24rpx;
  background: rgba(6, 18, 41, 0.62);
}

.section-title {
  color: #fff;
  font-size: 38rpx;
  font-weight: 900;
}

.section-title text {
  color: #5aa4ff;
}

.section-text {
  margin-top: 22rpx;
  color: rgba(235, 243, 255, 0.82);
  font-size: 26rpx;
  line-height: 1.8;
}
